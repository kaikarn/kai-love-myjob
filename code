<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ai เลขาของคุณกาย - Management Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Prompt:wght@300;400;600&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lucide/0.263.1/lucide.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'Prompt', 'Inter', sans-serif; background-color: #f8fafc; }
        .glass { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
        .kpi-card { background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%); }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .sidebar-transition { transition: transform 0.3s ease-in-out; }
        .postit-card { transition: all 0.3s; transform: rotate(-1deg); }
        .postit-card:hover { transform: rotate(0deg) scale(1.02); box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); }
        .mobile-menu-active { transform: translateX(0) !important; }
    </style>
</head>
<body class="min-h-screen text-slate-800 flex overflow-hidden">

    <script type="module">
        // Firebase Configuration (Placeholder - will use guest mode if unauthorized)
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.0.2/firebase-app.js";
        import { getAuth, signInWithPopup, GoogleAuthProvider, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/11.0.2/firebase-auth.js";

        // Constants
        const CATEGORIES = ['บริหาร', 'ออนไลน์', 'หน่วยรถ', 'โมเดิร์นเทรด', 'งานพัฒนาสินค้า', 'คำสั่งบอส', 'คำสั่งอาจารย์', 'งานออกแบบ', 'อบรม/ประชุม', 'งานประสานงาน', 'งานโปรเจค', 'ส่วนตัว', 'อื่นๆ'];
        const PRIORITIES = {
            urgent: { label: 'ด่วน', color: 'bg-rose-500', text: 'text-rose-600', bg: 'bg-rose-50', border: 'border-rose-200' },
            urgent_important: { label: 'สำคัญและด่วน', color: 'bg-orange-500', text: 'text-orange-600', bg: 'bg-orange-50', border: 'border-orange-200' },
            focus: { label: 'งานโฟกัส', color: 'bg-indigo-500', text: 'text-indigo-600', bg: 'bg-indigo-50', border: 'border-indigo-200' },
            general: { label: 'งานทั่วไป', color: 'bg-slate-400', text: 'text-slate-500', bg: 'bg-slate-50', border: 'border-slate-200' }
        };
        const STATUSES = {
            pending: { label: 'ยังไม่เริ่ม', color: 'text-slate-500', bg: 'bg-slate-100' },
            in_progress: { label: 'กำลังทำ', color: 'text-indigo-600', bg: 'bg-indigo-100' },
            completed: { label: 'เสร็จแล้ว', color: 'text-emerald-600', bg: 'bg-emerald-100' },
            closed: { label: 'ปิดงาน', color: 'text-white', bg: 'bg-slate-800' }
        };

        // Application State
        let tasks = JSON.parse(localStorage.getItem('kai_tasks_v5') || '[]');
        let postIts = JSON.parse(localStorage.getItem('kai_postits_v5') || '[]');
        let settings = JSON.parse(localStorage.getItem('kai_settings') || '{"notifyTime":"08:30"}');
        let currentView = 'dashboard';
        let calendarDate = new Date();
        let currentEditId = null;

        // Firebase Initialization with Error Handling for Preview/Domain
        let auth = null;
        try {
            const firebaseConfig = { apiKey: "MOCK_KEY", authDomain: "mock.firebaseapp.com" }; // Placeholder
            const app = initializeApp(firebaseConfig);
            auth = getAuth(app);
        } catch (e) {
            console.log("Firebase Auth disabled due to environment/config.");
        }

        // Global Exposed Functions (to be callable from HTML)
        window.switchView = (view, filterType = null) => {
            document.querySelectorAll('#view-container > div').forEach(el => el.classList.add('hidden'));
            const target = document.getElementById(`view-${view}`);
            if(target) target.classList.remove('hidden');
            
            document.querySelectorAll('aside nav button').forEach(el => el.classList.remove('bg-indigo-50', 'text-indigo-600', 'font-bold'));
            const btn = document.getElementById(`nav-${view}`);
            if(btn) btn.classList.add('bg-indigo-50', 'text-indigo-600', 'font-bold');

            document.getElementById('header-title').innerText = {dashboard:'แดชบอร์ดสรุปงาน', tasks:'รายการงานทั้งหมด', calendar:'ปฏิทินนัดหมาย', postits:'กระดานโน้ตด่วน', settings:'ตั้งค่าระบบ'}[view];
            
            if(view === 'dashboard') updateDashboard();
            if(view === 'tasks') renderTasks(filterType);
            if(view === 'calendar') renderCalendar();
            if(view === 'postits') renderPostItBoard();
            if(window.innerWidth < 1024) toggleSidebar(false);
            refreshIcons();
        };

        window.toggleSidebar = (state) => {
            const sb = document.getElementById('sidebar');
            if(state === undefined) sb.classList.toggle('mobile-menu-active');
            else if(state) sb.classList.add('mobile-menu-active');
            else sb.classList.remove('mobile-menu-active');
        };

        const updateDashboard = () => {
            const now = new Date();
            const stats = {
                pending: tasks.filter(t => t.status === 'pending').length,
                urgent: tasks.filter(t => (t.priority === 'urgent' || t.priority === 'urgent_important') && t.status !== 'closed').length,
                completed: tasks.filter(t => t.status === 'completed' || t.status === 'closed').length,
                near: tasks.filter(t => {
                    if(!t.deadline || t.status === 'closed') return false;
                    const diff = (new Date(t.deadline) - now) / (1000*60*60);
                    return diff > 0 && diff < 24;
                }).length
            };

            for(const k in stats) {
                const el = document.getElementById(`stat-${k}`);
                if(el) el.innerText = stats[k];
            }

            const total = tasks.length || 1;
            const successRate = Math.round((stats.completed / total) * 100);
            const overall = successRate; // Simplified for display

            document.getElementById('kpi-success-rate').innerText = successRate + '%';
            document.getElementById('kpi-total-perc').innerText = overall + '%';
            
            const circle = document.getElementById('kpi-circle');
            if(circle) circle.style.strokeDashoffset = 502.6 - (502.6 * overall / 100);

            const aiInsight = document.getElementById('ai-insight');
            if(stats.urgent > 0) aiInsight.innerText = `คุณกายครับ มีงานด่วนที่ต้องเร่งจัดการ ${stats.urgent} รายการ แนะนำให้เริ่มก่อนครับ`;
            else aiInsight.innerText = `ยินดีด้วยครับคุณกาย วันนี้ภาพรวมงานค่อนข้างเรียบร้อย KPI อยู่ในระดับที่น่าพอใจครับ`;
        };

        window.renderTasks = (specialFilter = null) => {
            const grid = document.getElementById('task-grid');
            const status = document.getElementById('filter-status').value;
            const prio = document.getElementById('filter-priority').value;
            const cat = document.getElementById('filter-category').value;
            const date = document.getElementById('filter-date-start').value;

            let filtered = tasks.filter(t => {
                let m = true;
                if(status !== 'all' && t.status !== status) m = false;
                if(prio !== 'all' && t.priority !== prio) m = false;
                if(cat !== 'all' && t.category !== cat) m = false;
                if(date && !t.deadline?.startsWith(date)) m = false;

                if(specialFilter === 'urgent' && !(t.priority === 'urgent' || t.priority === 'urgent_important')) m = false;
                if(specialFilter === 'near') {
                    if(t.status === 'closed') return false;
                    const diff = (new Date(t.deadline) - new Date()) / (1000*60*60);
                    if(!(diff > 0 && diff < 24)) m = false;
                }
                return m;
            });

            grid.innerHTML = filtered.length ? filtered.map(t => {
                const p = PRIORITIES[t.priority] || PRIORITIES.general;
                const s = STATUSES[t.status] || STATUSES.pending;
                return `
                    <div onclick="openTaskModal('${t.id}')" class="task-card glass p-6 rounded-[2rem] border border-slate-200 cursor-pointer flex flex-col h-full">
                        <div class="flex justify-between items-start mb-4">
                            <span class="text-[9px] font-bold px-2.5 py-1 rounded-lg ${p.bg} ${p.text} border ${p.border}">${p.label}</span>
                            <span class="text-[9px] font-bold px-2.5 py-1 rounded-lg ${s.bg} ${s.color}">${s.label}</span>
                        </div>
                        <h4 class="font-bold text-slate-800 mb-2 line-clamp-1">${t.title}</h4>
                        <p class="text-xs text-slate-400 line-clamp-2 mb-4 flex-1">${t.description || 'ไม่มีรายละเอียด'}</p>
                        <div class="pt-4 border-t border-slate-50 flex items-center justify-between text-[10px] font-bold text-slate-400">
                            <span># ${t.category}</span>
                            <span>${t.deadline ? new Date(t.deadline).toLocaleDateString('th-TH') : ''}</span>
                        </div>
                    </div>
                `;
            }).join('') : `<div class="col-span-full py-20 text-center text-slate-300 font-bold">ไม่พบรายการงานครับ</div>`;
            refreshIcons();
        };

        window.openTaskModal = (id = null) => {
            currentEditId = id;
            document.getElementById('task-modal').classList.remove('hidden');
            document.getElementById('modal-title').innerText = id ? "แก้ไขรายละเอียดงาน" : "สั่งงานใหม่คุณกาย";
            
            // Populate Dropdowns
            document.getElementById('task-cat-select').innerHTML = CATEGORIES.map(c => `<option value="${c}">${c}</option>`).join('');
            document.getElementById('task-prio-select').innerHTML = Object.keys(PRIORITIES).map(k => `<option value="${k}">${PRIORITIES[k].label}</option>`).join('');
            document.getElementById('task-status-select').innerHTML = Object.keys(STATUSES).map(k => `<option value="${k}">${STATUSES[k].label}</option>`).join('');

            if(id) {
                const t = tasks.find(x => x.id === id);
                document.getElementById('task-title').value = t.title;
                document.getElementById('task-desc').value = t.description;
                document.getElementById('task-cat-select').value = t.category;
                document.getElementById('task-prio-select').value = t.priority;
                document.getElementById('task-reminder').value = t.reminder || '';
                document.getElementById('task-deadline').value = t.deadline || '';
                document.getElementById('task-link').value = t.link || '';
                document.getElementById('task-status-select').value = t.status;
                document.getElementById('btn-delete').classList.remove('hidden');
            } else {
                document.querySelectorAll('#task-modal input, #task-modal textarea').forEach(el => el.value = '');
                document.getElementById('btn-delete').classList.add('hidden');
            }
            refreshIcons();
        };

        window.closeTaskModal = () => document.getElementById('task-modal').classList.add('hidden');

        window.saveTask = () => {
            const data = {
                id: currentEditId || Date.now().toString(),
                title: document.getElementById('task-title').value,
                description: document.getElementById('task-desc').value,
                category: document.getElementById('task-cat-select').value,
                priority: document.getElementById('task-prio-select').value,
                reminder: document.getElementById('task-reminder').value,
                deadline: document.getElementById('task-deadline').value,
                link: document.getElementById('task-link').value,
                status: document.getElementById('task-status-select').value,
                updatedAt: new Date().toISOString()
            };

            if(!data.title) return;

            if(currentEditId) tasks = tasks.map(t => t.id === currentEditId ? data : t);
            else tasks.push(data);

            localStorage.setItem('kai_tasks_v5', JSON.stringify(tasks));
            closeTaskModal();
            renderTasks();
            updateDashboard();
        };

        window.deleteTask = () => {
            if(confirm("ยืนยันการลบงานนี้ใช่ไหมครับคุณกาย?")) {
                tasks = tasks.filter(t => t.id !== currentEditId);
                localStorage.setItem('kai_tasks_v5', JSON.stringify(tasks));
                closeTaskModal();
                renderTasks();
                updateDashboard();
            }
        };

        window.changeMonth = (v) => { calendarDate.setMonth(calendarDate.getMonth() + v); renderCalendar(); };
        window.renderCalendar = () => {
            const grid = document.getElementById('calendar-grid');
            const title = document.getElementById('calendar-title');
            const year = calendarDate.getFullYear();
            const month = calendarDate.getMonth();
            title.innerText = new Intl.DateTimeFormat('th-TH', { month: 'long', year: 'numeric' }).format(calendarDate);

            const first = new Date(year, month, 1).getDay();
            const days = new Date(year, month + 1, 0).getDate();

            let html = ['อา','จ','อ','พ','พฤ','ศ','ส'].map(d => `<div class="bg-white p-3 text-center text-[10px] font-bold text-slate-300 uppercase">${d}</div>`).join('');
            for(let i=0; i<first; i++) html += `<div class="bg-slate-50/50 h-24 sm:h-32"></div>`;
            for(let d=1; d<=days; d++) {
                const dateS = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
                const dayTasks = tasks.filter(t => t.deadline?.startsWith(dateS));
                const hasTask = dayTasks.length > 0;
                html += `
                    <div ${hasTask ? `onclick="switchView('tasks'); document.getElementById('filter-date-start').value='${dateS}'; renderTasks();"` : ''} 
                         class="bg-white h-24 sm:h-32 p-2 border-t border-l border-slate-100 flex flex-col ${hasTask ? 'cursor-pointer hover:bg-indigo-50' : 'opacity-80'}">
                        <span class="text-xs font-bold ${hasTask ? 'text-indigo-600' : 'text-slate-300'}">${d}</span>
                        <div class="mt-1 space-y-1 overflow-hidden">
                            ${dayTasks.slice(0, 2).map(t => `<div class="text-[8px] truncate bg-indigo-50 text-indigo-700 p-1 rounded font-bold">${t.title}</div>`).join('')}
                        </div>
                    </div>
                `;
            }
            grid.innerHTML = html;
        };

        window.renderPostItBoard = () => {
            const grid = document.getElementById('postit-grid');
            const colors = ['bg-yellow-50', 'bg-sky-50', 'bg-emerald-50', 'bg-rose-50', 'bg-violet-50'];
            grid.innerHTML = postIts.length ? postIts.map((p, i) => `
                <div class="postit-card ${colors[i % colors.length]} p-6 rounded-[2rem] aspect-square flex flex-col relative group">
                    <button onclick="deletePostIt('${p.id}')" class="absolute top-4 right-4 p-2 bg-white/50 opacity-0 group-hover:opacity-100 rounded-xl hover:text-rose-500 transition-all">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                    <textarea onblur="savePostIt('${p.id}', this.value)" 
                        class="flex-1 w-full bg-transparent border-none text-slate-700 font-medium outline-none resize-none text-sm leading-relaxed" 
                        placeholder="พิมพ์โน้ต...">${p.text}</textarea>
                </div>
            `).join('') : '';
            refreshIcons();
        };

        window.addPostIt = () => {
            postIts.unshift({ id: Date.now().toString(), text: '' });
            localStorage.setItem('kai_postits_v5', JSON.stringify(postIts));
            renderPostItBoard();
        };

        window.savePostIt = (id, text) => {
            postIts = postIts.map(p => p.id === id ? { ...p, text } : p);
            localStorage.setItem('kai_postits_v5', JSON.stringify(postIts));
        };

        window.deletePostIt = (id) => {
            postIts = postIts.filter(p => p.id !== id);
            localStorage.setItem('kai_postits_v5', JSON.stringify(postIts));
            renderPostItBoard();
        };

        window.saveSettings = () => {
            const time = document.getElementById('set-notify-time').value;
            settings.notifyTime = time;
            localStorage.setItem('kai_settings', JSON.stringify(settings));
            alert("บันทึกเวลาแจ้งเตือนเรียบร้อยครับคุณกาย");
        };

        window.login = () => {
            if(!auth) { alert("ขณะนี้อยู่ใน Guest Mode (ข้อมูลจะบันทึกในเครื่อง) เนื่องจากติดข้อจำกัดด้านความปลอดภัยของเบราว์เซอร์ครับ"); return; }
            signInWithPopup(auth, new GoogleAuthProvider())
                .catch(err => alert("เกิดข้อผิดพลาดในการล็อกอิน: " + err.message));
        };

        window.logout = () => {
            if(auth) signOut(auth).then(() => location.reload());
            else location.reload();
        };

        window.exportToCSV = () => {
            const h = ["ชื่อเรื่อง", "หมวดหมู่", "ความสำคัญ", "สถานะ", "กำหนดส่ง"];
            const r = tasks.map(t => [t.title, t.category, t.priority, t.status, t.deadline]);
            const csv = "\uFEFF" + [h, ...r].map(i => i.join(",")).join("\n");
            const b = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const a = document.createElement("a");
            a.href = URL.createObjectURL(b);
            a.download = `tasks_guy_${new Date().toLocaleDateString()}.csv`;
            a.click();
        };

        // Initialize
        window.onload = () => {
            document.getElementById('filter-category').innerHTML += CATEGORIES.map(c => `<option value="${c}">${c}</option>`).join('');
            document.getElementById('filter-priority').innerHTML += Object.keys(PRIORITIES).map(k => `<option value="${k}">${PRIORITIES[k].label}</option>`).join('');
            document.getElementById('set-notify-time').value = settings.notifyTime;
            
            // Check Auth (Fallback if Firebase blocks domain)
            if(auth) {
                onAuthStateChanged(auth, (user) => {
                    if(user) {
                        document.getElementById('login-overlay').classList.add('hidden');
                        document.getElementById('user-name').innerText = user.displayName;
                    }
                });
            } else {
                // If Firebase fails (Unauthorized domain), allow Guest Mode in Preview
                document.getElementById('login-overlay').classList.add('hidden');
            }
            
            switchView('dashboard');
        };
    </script>

    <!-- UI Components -->
    <div id="login-overlay" class="fixed inset-0 bg-slate-900 z-[1000] flex items-center justify-center p-6">
        <div class="glass p-10 rounded-[3rem] text-center max-w-sm w-full border border-white/20 shadow-2xl">
            <div class="w-16 h-16 bg-indigo-600 rounded-3xl flex items-center justify-center mx-auto mb-6 shadow-lg shadow-indigo-200">
                <i data-lucide="sparkles" class="text-white w-8 h-8"></i>
            </div>
            <h1 class="text-2xl font-bold text-slate-800 mb-2">ยินดีต้อนรับครับ</h1>
            <p class="text-slate-500 text-sm mb-10 leading-relaxed">กรุณาล็อกอินเพื่อเข้าสู่ระบบเลขาของคุณกาย และเข้าถึงข้อมูลแบบเรียลไทม์</p>
            <button onclick="login()" class="w-full py-4 bg-white border border-slate-200 rounded-2xl font-bold flex items-center justify-center gap-3 hover:bg-slate-50 transition-all shadow-sm">
                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/action/google/light_normal.svg" class="w-5 h-5">
                เข้าใช้งานผ่าน Google
            </button>
            <p class="mt-6 text-[10px] text-slate-400">ระบบจะทำการซิงค์ข้อมูลลงบน Cloud อัตโนมัติ</p>
        </div>
    </div>

    <!-- Sidebar -->
    <aside id="sidebar" class="w-72 glass border-r border-slate-200 flex flex-col h-screen fixed inset-y-0 left-0 lg:relative z-50 -translate-x-full lg:translate-x-0 sidebar-transition">
        <div class="p-8 flex justify-between items-center">
            <h1 class="text-xl font-bold bg-gradient-to-r from-indigo-600 to-violet-700 bg-clip-text text-transparent flex items-center gap-2">
                <i data-lucide="sparkles" class="text-indigo-600 w-5 h-5"></i> Ai เลขากาย
            </h1>
            <button onclick="toggleSidebar(false)" class="lg:hidden p-2 hover:bg-slate-100 rounded-lg"><i data-lucide="x"></i></button>
        </div>

        <nav class="flex-1 px-4 space-y-1 overflow-y-auto custom-scrollbar">
            <button onclick="switchView('dashboard')" id="nav-dashboard" class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl transition-all hover:bg-slate-50 group font-bold">
                <i data-lucide="layout-dashboard"></i> แดชบอร์ด
            </button>
            <button onclick="switchView('tasks')" id="nav-tasks" class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl transition-all hover:bg-slate-50 group">
                <i data-lucide="list-checks"></i> งานทั้งหมด
            </button>
            <button onclick="switchView('calendar')" id="nav-calendar" class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl transition-all hover:bg-slate-50 group">
                <i data-lucide="calendar"></i> ปฏิทินนัดหมาย
            </button>
            <button onclick="switchView('postits')" id="nav-postits" class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl transition-all hover:bg-slate-50 group">
                <i data-lucide="sticky-note"></i> กระดานโน้ตด่วน
            </button>
            <button onclick="switchView('settings')" id="nav-settings" class="w-full flex items-center gap-3 px-5 py-4 rounded-2xl transition-all hover:bg-slate-50 group">
                <i data-lucide="settings"></i> ตั้งค่าระบบ
            </button>
        </nav>

        <div class="p-6 border-t border-slate-100 space-y-4">
            <button onclick="openTaskModal()" class="w-full py-4 bg-indigo-600 text-white rounded-2xl font-bold shadow-lg hover:bg-indigo-700 active:scale-95 transition-all flex items-center justify-center gap-2">
                <i data-lucide="plus-circle"></i> สั่งงานใหม่
            </button>
            <button onclick="logout()" class="w-full py-3 text-rose-500 font-bold text-xs hover:bg-rose-50 rounded-xl transition-all flex items-center justify-center gap-2">
                <i data-lucide="log-out" class="w-4 h-4"></i> ออกจากระบบ
            </button>
        </div>
    </aside>

    <main class="flex-1 flex flex-col h-screen overflow-hidden">
        <header class="h-20 glass border-b border-slate-200 px-6 sm:px-8 flex items-center justify-between shrink-0">
            <div class="flex items-center gap-4">
                <button onclick="toggleSidebar(true)" class="lg:hidden p-2 hover:bg-slate-100 rounded-lg"><i data-lucide="menu"></i></button>
                <h2 id="header-title" class="text-lg font-bold text-slate-800">แดชบอร์ดสรุปงาน</h2>
            </div>
            <div class="flex items-center gap-3 pl-4 border-l border-slate-200">
                <p id="user-name" class="text-xs font-bold text-slate-800 hidden sm:block">คุณกาย</p>
                <div class="h-10 w-10 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600 font-bold">K</div>
            </div>
        </header>

        <div id="view-container" class="flex-1 overflow-y-auto p-4 sm:p-8 custom-scrollbar">
            
            <!-- Dashboard -->
            <div id="view-dashboard" class="space-y-6">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <div class="lg:col-span-2 kpi-card p-6 sm:p-8 rounded-[2.5rem] text-white shadow-xl relative overflow-hidden">
                        <div class="relative z-10 flex flex-col sm:flex-row items-center justify-between gap-6">
                            <div class="flex-1">
                                <h3 class="text-xl font-bold mb-1">สรุปผลงาน KPI</h3>
                                <p class="text-indigo-100 text-[10px] mb-4 opacity-70">วิเคราะห์ตามความสำเร็จของรายการงาน</p>
                                <div class="grid grid-cols-2 gap-3">
                                    <div class="bg-white/10 backdrop-blur-md p-4 rounded-2xl border border-white/20">
                                        <p class="text-[9px] uppercase font-bold text-indigo-200 mb-1">Success</p>
                                        <h4 id="kpi-success-rate" class="text-2xl font-bold">0%</h4>
                                    </div>
                                    <div class="bg-white/10 backdrop-blur-md p-4 rounded-2xl border border-white/20">
                                        <p class="text-[9px] uppercase font-bold text-indigo-200 mb-1">Target</p>
                                        <h4 class="text-2xl font-bold">100%</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="w-32 h-32 relative flex items-center justify-center shrink-0">
                                <svg class="w-full h-full transform -rotate-90">
                                    <circle cx="64" cy="64" r="58" stroke="currentColor" stroke-width="8" fill="transparent" class="text-indigo-400/30" />
                                    <circle id="kpi-circle" cx="64" cy="64" r="58" stroke="currentColor" stroke-width="8" fill="transparent" stroke-dasharray="364.4" stroke-dashoffset="364.4" class="text-white transition-all duration-1000" />
                                </svg>
                                <span id="kpi-total-perc" class="absolute text-2xl font-bold">0%</span>
                            </div>
                        </div>
                    </div>
                    <div class="glass p-6 rounded-[2.5rem] border border-slate-200 flex flex-col">
                        <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2"><i data-lucide="brain" class="text-indigo-600"></i> AI เลขาแนะนำ</h3>
                        <div id="ai-insight" class="text-sm text-slate-600 leading-relaxed italic bg-slate-50 p-5 rounded-2xl border border-slate-100 flex-1">
                            กำลังวิเคราะห์รายการงาน...
                        </div>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                    <div class="glass p-5 rounded-3xl border border-slate-100"><p class="text-[10px] font-bold text-slate-400 uppercase mb-1">งานค้าง</p><h4 id="stat-pending" class="text-2xl font-bold">0</h4></div>
                    <div class="glass p-5 rounded-3xl border border-slate-100"><p class="text-[10px] font-bold text-rose-400 uppercase mb-1">งานด่วน</p><h4 id="stat-urgent" class="text-2xl font-bold text-rose-600">0</h4></div>
                    <div class="glass p-5 rounded-3xl border border-slate-100"><p class="text-[10px] font-bold text-orange-400 uppercase mb-1">ใกล้ส่ง</p><h4 id="stat-near" class="text-2xl font-bold text-orange-600">0</h4></div>
                    <div class="glass p-5 rounded-3xl border border-slate-100"><p class="text-[10px] font-bold text-emerald-400 uppercase mb-1">สำเร็จ</p><h4 id="stat-completed" class="text-2xl font-bold text-emerald-600">0</h4></div>
                </div>
            </div>

            <!-- Tasks -->
            <div id="view-tasks" class="hidden space-y-6">
                <div class="glass p-5 rounded-[2rem] border border-slate-200 flex flex-wrap gap-3 items-center justify-between">
                    <div class="flex flex-wrap gap-3">
                        <select id="filter-status" onchange="renderTasks()" class="bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold px-4 py-2 outline-none">
                            <option value="all">ทุกสถานะ</option>
                            <option value="pending">ยังไม่เริ่ม</option>
                            <option value="in_progress">กำลังทำ</option>
                            <option value="completed">เสร็จแล้ว</option>
                            <option value="closed">ปิดงาน</option>
                        </select>
                        <select id="filter-priority" onchange="renderTasks()" class="bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold px-4 py-2 outline-none">
                            <option value="all">ทุกความสำคัญ</option>
                        </select>
                        <select id="filter-category" onchange="renderTasks()" class="bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold px-4 py-2 outline-none">
                            <option value="all">ทุกหมวดหมู่</option>
                        </select>
                        <input type="date" id="filter-date-start" onchange="renderTasks()" class="bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold px-4 py-2 outline-none">
                    </div>
                    <button onclick="exportToCSV()" class="p-2 bg-indigo-50 text-indigo-600 rounded-xl font-bold text-xs hover:bg-indigo-100 transition-all">ดาวน์โหลดตาราง</button>
                </div>
                <div id="task-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6"></div>
            </div>

            <!-- Calendar -->
            <div id="view-calendar" class="hidden glass p-6 rounded-[2.5rem] border border-slate-200">
                <div class="flex justify-between items-center mb-6">
                    <h2 id="calendar-title" class="text-2xl font-bold text-slate-800"></h2>
                    <div class="flex gap-2">
                        <button onclick="changeMonth(-1)" class="p-2 hover:bg-slate-100 rounded-xl"><i data-lucide="chevron-left"></i></button>
                        <button onclick="changeMonth(1)" class="p-2 hover:bg-slate-100 rounded-xl"><i data-lucide="chevron-right"></i></button>
                    </div>
                </div>
                <div id="calendar-grid" class="grid grid-cols-7 gap-px bg-slate-100 rounded-2xl overflow-hidden border border-slate-100"></div>
            </div>

            <!-- Post-its -->
            <div id="view-postits" class="hidden space-y-6">
                <div class="flex justify-between items-center">
                    <h2 class="text-2xl font-bold text-slate-800">กระดานโน้ตด่วน</h2>
                    <button onclick="addPostIt()" class="px-6 py-3 bg-indigo-600 text-white rounded-2xl font-bold shadow-md flex items-center gap-2"><i data-lucide="plus"></i> เพิ่มโน้ต</button>
                </div>
                <div id="postit-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6"></div>
            </div>

            <!-- Settings -->
            <div id="view-settings" class="hidden space-y-6 max-w-lg mx-auto">
                <div class="glass p-8 rounded-[2.5rem] border border-slate-200">
                    <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2"><i data-lucide="bell" class="text-indigo-600"></i> การแจ้งเตือน</h2>
                    <div class="space-y-4">
                        <label class="block text-[10px] font-bold text-slate-400 uppercase">เวลาแจ้งเตือนสรุปงานยามเช้า</label>
                        <div class="flex gap-3">
                            <input type="time" id="set-notify-time" class="flex-1 p-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none font-bold">
                            <button onclick="saveSettings()" class="px-8 bg-indigo-600 text-white rounded-2xl font-bold">บันทึก</button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <!-- Task Modal -->
    <div id="task-modal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[200] flex items-center justify-center hidden p-4">
        <div class="glass w-full max-w-xl rounded-[3rem] shadow-2xl border border-white/20 p-8 max-h-[90vh] overflow-y-auto custom-scrollbar">
            <div class="flex justify-between items-center mb-6">
                <h2 id="modal-title" class="text-xl font-bold text-slate-800">สั่งงานใหม่</h2>
                <button onclick="closeTaskModal()" class="p-2 hover:bg-slate-100 rounded-full text-slate-400"><i data-lucide="x"></i></button>
            </div>
            <div class="space-y-4">
                <input type="text" id="task-title" placeholder="ชื่อเรื่อง" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none font-medium">
                <textarea id="task-desc" placeholder="รายละเอียด..." rows="3" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none font-medium"></textarea>
                <div class="grid grid-cols-2 gap-4">
                    <select id="task-cat-select" class="p-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none"></select>
                    <select id="task-prio-select" class="p-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none"></select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-[9px] font-bold text-slate-400 ml-1">Reminder</label>
                        <input type="datetime-local" id="task-reminder" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl">
                    </div>
                    <div>
                        <label class="text-[9px] font-bold text-slate-400 ml-1">Deadline</label>
                        <input type="datetime-local" id="task-deadline" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <input type="url" id="task-link" placeholder="Link งาน" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl">
                    <select id="task-status-select" class="p-4 bg-slate-50 border border-slate-200 rounded-2xl"></select>
                </div>
                <div class="flex gap-4 pt-4">
                    <button id="btn-delete" onclick="deleteTask()" class="px-6 py-4 bg-rose-50 text-rose-600 rounded-2xl font-bold hover:bg-rose-100 transition-all hidden">ลบ</button>
                    <button onclick="saveTask()" class="flex-1 py-4 bg-indigo-600 text-white rounded-2xl font-bold shadow-lg active:scale-[0.98] transition-all">บันทึกข้อมูล</button>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
